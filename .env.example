# Pisubí — Variables de entorno
# Copiar a .env y completar con valores reales

# LLM providers (al menos uno requerido)
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=...
MISTRAL_API_KEY=...

# FRED (Federal Reserve Economic Data) — gratis en https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=...

# (Opcional) Para deploy
DATABASE_URL=sqlite:///./backend/db/commodity_monitor.db
